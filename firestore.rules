rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isCoupleOf(coupleId) {
      return isLoggedIn() && (
        coupleId.split('_')[0] == request.auth.uid ||
        coupleId.split('_')[1] == request.auth.uid
      );
    }

    match /users/{uid} {
      allow read: if isLoggedIn();
      allow create: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid;
      allow delete: if false;
    }

    match /invites/{code} {
      allow read, write: if isLoggedIn();
    }

    // changelog 是全域共用（非 couple-scoped），任何登入者可讀；只有管理員可寫（由 JS 判斷，這裡僅限登入）
    match /changelog/{docId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn();
    }

    match /couples/{coupleId} {
      allow read, write: if isCoupleOf(coupleId);

      match /messages/{msgId} {
        allow read, write: if isCoupleOf(coupleId);
      }
      match /list/{itemId} {
        allow read, write: if isCoupleOf(coupleId);
      }
      match /rests/{restId} {
        allow read, write: if isCoupleOf(coupleId);
      }
      match /challenges/{chalId} {
        allow read, write: if isCoupleOf(coupleId);
      }
      match /quotes/{quoteId} {
        allow read, write: if isCoupleOf(coupleId);
      }
      match /memories/{memId} {
        allow read, write: if isCoupleOf(coupleId);
      }
      match /events/{eventId} {
        allow read, write: if isCoupleOf(coupleId);
      }
    }
  }
}
