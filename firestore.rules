rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    // coupleId 是兩個 uid 用 _ 串接（排序後），檢查目前使用者是否是其中一員
    function isCoupleOf(coupleId) {
      return isLoggedIn() && (
        coupleId.split('_')[0] == request.auth.uid ||
        coupleId.split('_')[1] == request.auth.uid
      );
    }

    match /users/{uid} {
      allow read: if isLoggedIn();
      allow create: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid;
      allow delete: if false;
    }

    match /invites/{code} {
      allow read, write: if isLoggedIn();
    }

    match /couples/{coupleId} {
      allow read, write: if isCoupleOf(coupleId);

      match /messages/{msgId} {
        allow read, write: if isCoupleOf(coupleId);
      }
      match /list/{itemId} {
        allow read, write: if isCoupleOf(coupleId);
      }
      match /rests/{restId} {
        allow read, write: if isCoupleOf(coupleId);
      }
      match /challenges/{chalId} {
        allow read, write: if isCoupleOf(coupleId);
      }
      match /quotes/{quoteId} {
        allow read, write: if isCoupleOf(coupleId);
      }
    }
  }
}